    "collapsible_content_39KBaG": {
      "type": "collapsible-content",
      "blocks": {
        "collapsible_row_bxye8z": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What is SHMNI?",
            "icon": "bottle",
            "row_content": "<p>SHMNI is a fragrance brand offering high-quality perfumes at lower prices. We specialize in crafting scents inspired by well-known brands, allowing you to enjoy the same delightful aromas without paying for the brand name. Why pay a premium for the label when you can get the essence of your favorite cologne at a fraction of the cost?<\/p><p>At SHMNI, we believe that everyone deserves to indulge in luxurious scents. Our fragrances are meticulously crafted to mirror the essence of high-end brands, ensuring you get the best of both worlds: exceptional quality and affordability. Embrace the luxury of premium fragrances with SHMNI, and discover your new signature scent today.<\/p>",
            "page": ""
          }
        },
        "collapsible_row_nmzRa4": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Where is SHMNI made?",
            "icon": "bottle",
            "row_content": "<p>SHMNI is made in the USA, with our headquarters located in California. Our fragrance oils are sourced from top-quality ingredients in Switzerland, France, and other parts of Europe.<\/p>",
            "page": ""
          }
        },
        "collapsible_row_ehNj7U": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Will I receive any gifts?",
            "icon": "bottle",
            "row_content": "<p>Maybe 😉<\/p>",
            "page": ""
          }
        },
        "collapsible_row_RD7eKd": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Return Policy",
            "icon": "return",
            "row_content": "<p>If the product is damage, or not what you expected please contact us!<\/p><p>We will try our best to help <\/p>",
            "page": ""
          }
        }
      },
