<style>
  .custom-testimonials-wrapper {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0;
    background-color: {{ section.settings.bg_color }};
    overflow: hidden;
  }
  .custom-testimonials-header {
    text-align: center;
    margin-bottom: 40px;
    padding: 0 20px;
  }
  .custom-testimonials-header h2 {
    font-size: 32px;
    margin: 0;
    color: {{ section.settings.text_color }};
    font-weight: 600;
    letter-spacing: 1px;
  }
  .custom-testimonials-slider {
    overflow: hidden;
    width: 100%;
    padding: 20px 0;
    position: relative;
    /* Hide scrollbar for neatness if any */
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .custom-testimonials-slider::-webkit-scrollbar {
    display: none;
  }
  .marquee-track {
    display: inline-flex;
    gap: 24px;
    /* Add padding to start and end for initial layout */
    padding: 0 12px;
    animation: marquee-scroll 40s linear infinite;
  }
  .marquee-track:hover {
    animation-play-state: paused;
  }
  @keyframes marquee-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(calc(-50% - 12px)); }
  }
  .custom-testimonial-card {
    flex: 0 0 300px;
    background: #ffffff;
    border-radius: 12px;
    padding: 30px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    white-space: normal;
  }
  /* Dark Mode specific overrides */
  html.theme-dark .custom-testimonial-card {
    background: #1a1a1a;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
  }
  html.theme-dark .custom-testimonial-text { color: #ccc; }
  html.theme-dark .custom-testimonial-name { color: #fff; }
  html.theme-dark .custom-testimonials-header h2 { color: #fff; }
  html.theme-dark .custom-testimonials-wrapper { background-color: #121212 !important; }

  @media (min-width: 768px) {
    .custom-testimonial-card {
      flex: 0 0 360px;
    }
  }
  .custom-testimonial-stars {
    display: flex;
    gap: 4px;
    margin-bottom: 15px;
  }
  .custom-testimonial-stars svg {
    width: 14px;
    height: 14px;
    fill: #D4AF37;
  }
  .custom-testimonial-text {
    font-size: 15px;
    line-height: 1.6;
    color: #4a4a4a;
    margin-bottom: 24px;
    font-style: normal;
  }
  .custom-testimonial-author {
    display: flex;
    align-items: center;
  }
  .custom-testimonial-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
    margin-right: 12px;
    background-color: #f0f0f0;
  }
  .custom-testimonial-author-info {
    display: flex;
    flex-direction: column;
  }
  .custom-testimonial-name {
    font-weight: 600;
    font-size: 14px;
    color: #121212;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .custom-testimonial-verified {
    font-size: 11px;
    color: #888888;
    display: flex;
    align-items: center;
    gap: 5px;
    margin-top: 4px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .custom-testimonial-verified svg {
    width: 12px;
    height: 12px;
    fill: #4CAF50;
  }
</style>

<div class="custom-testimonials-wrapper">
  {% if section.settings.title != blank %}
    <div class="custom-testimonials-header">
      <h2>{{ section.settings.title }}</h2>
    </div>
  {% endif %}
  <div class="custom-testimonials-slider">
    <div class="marquee-track">
      <!-- Original Set -->
      {% for block in section.blocks %}
        <div class="custom-testimonial-card" {{ block.shopify_attributes }}>
          <div class="custom-testimonial-stars">
            {% for i in (1..5) %}
              <svg viewBox="0 0 24 24"><path d="M12 .587l3.668 7.568 8.332 1.151-6.064 5.828 1.48 8.279-7.416-3.967-7.417 3.967 1.481-8.279-6.064-5.828 8.332-1.151z"/></svg>
            {% endfor %}
          </div>
          <div class="custom-testimonial-text">
            "{{ block.settings.review_text }}"
          </div>
          <div class="custom-testimonial-author">
            {% if block.settings.author_image != blank %}
              <img src="{{ block.settings.author_image | image_url: width: 88 }}" width="44" height="44" class="custom-testimonial-avatar" alt="{{ block.settings.author_name }}">
            {% else %}
              <div class="custom-testimonial-avatar" style="display:flex;align-items:center;justify-content:center;font-size:16px;color:#888;font-weight:bold;">{{ block.settings.author_name | slice: 0, 1 }}</div>
            {% endif %}
            <div class="custom-testimonial-author-info">
              <span class="custom-testimonial-name">{{ block.settings.author_name }}</span>
              {% if block.settings.show_verified %}
                <span class="custom-testimonial-verified">
                  <svg viewBox="0 0 24 24"><path d="M9 16.172l-4.172-4.172-1.414 1.414L9 19 21 7l-1.414-1.414z"/></svg>
                  Verified Customer
                </span>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
      
      <!-- Duplicated Set for Infinite Loop -->
      {% for block in section.blocks %}
        <div class="custom-testimonial-card">
          <div class="custom-testimonial-stars">
            {% for i in (1..5) %}
              <svg viewBox="0 0 24 24"><path d="M12 .587l3.668 7.568 8.332 1.151-6.064 5.828 1.48 8.279-7.416-3.967-7.417 3.967 1.481-8.279-6.064-5.828 8.332-1.151z"/></svg>
            {% endfor %}
          </div>
          <div class="custom-testimonial-text">
            "{{ block.settings.review_text }}"
          </div>
          <div class="custom-testimonial-author">
            {% if block.settings.author_image != blank %}
              <img src="{{ block.settings.author_image | image_url: width: 88 }}" width="44" height="44" class="custom-testimonial-avatar" alt="{{ block.settings.author_name }}">
            {% else %}
              <div class="custom-testimonial-avatar" style="display:flex;align-items:center;justify-content:center;font-size:16px;color:#888;font-weight:bold;">{{ block.settings.author_name | slice: 0, 1 }}</div>
            {% endif %}
            <div class="custom-testimonial-author-info">
              <span class="custom-testimonial-name">{{ block.settings.author_name }}</span>
              {% if block.settings.show_verified %}
                <span class="custom-testimonial-verified">
                  <svg viewBox="0 0 24 24"><path d="M9 16.172l-4.172-4.172-1.414 1.414L9 19 21 7l-1.414-1.414z"/></svg>
                  Verified Customer
                </span>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
