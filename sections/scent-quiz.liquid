  // 2. Real-Time Shopify Data (Fetched on page load to ensure Live URLs & Images)
  var liveProducts = [];
  
  {% paginate collections['all'].products by 250 %}
    {% for p in collections['all'].products %}
      liveProducts.push({
        handle: {{ p.handle | json }},
        title: {{ p.title | json }},
        url: {{ p.url | json }},
        image: {{ p.featured_image | image_url: width: 400 | json }}
      });
    {% endfor %}
  {% endpaginate %}

  // 3. Fusion: Merge Live Data with AI Tags
  var productDatabase = [];
  
  liveProducts.forEach(function(liveProd) {
    var tags = aiDictionary[liveProd.handle];
    
    // Fallback for brand new products added after the dictionary was generated
    if (!tags) {
      tags = {
        gender: "unisex",
        vibe: "fresh",
        occasion: "everyday",
        short_desc: "Signature Blend"
      };
    }
    
    productDatabase.push({
      handle: liveProd.handle,
      title: liveProd.title,
      url: liveProd.url,
      image: liveProd.image,
      short_desc: tags.short_desc,
      gender: tags.gender,
      vibe: tags.vibe,
      occasion: tags.occasion
    });
  });

  var userAnswers = {
    gender: '',
    vibe: '',
    occasion: ''
  };

  function nextStep(stepIdx) {
    document.querySelectorAll('.quiz-step').forEach(el => el.classList.remove('active'));
    document.getElementById('step-' + stepIdx).classList.add('active');
  }

  function saveAnswer(key, value, nextIdx) {
    userAnswers[key] = value;
    
    if (nextIdx === 'loading') {
      nextStep('loading');
      setTimeout(calculateResults, 2000);
    } else {
      nextStep(nextIdx);
    }
  }

  function calculateResults() {
    nextStep('results');
    
    var container = document.getElementById('quiz-results-container');
    container.innerHTML = ''; // Clear old results
    
    var scoredCards = [];
    
    productDatabase.forEach(function(prod) {
      var score = 0;
      
      if (prod.gender === userAnswers.gender || prod.gender === 'unisex' || userAnswers.gender === 'unisex') {
        score += 2;
      }
      if (prod.vibe === userAnswers.vibe || prod.vibe === 'any') {
        score += 3;
      }
      if (prod.occasion === userAnswers.occasion || prod.occasion === 'any') {
        score += 1;
      }
      
      scoredCards.push({ product: prod, score: score });
    });
    
    // Sort highest score first
    scoredCards.sort(function(a, b) { return b.score - a.score; });
    
    var revealLimit = Math.min(3, scoredCards.length);
    var matchCount = 0;
    
    for (var i = 0; i < revealLimit; i++) {
      if (scoredCards[i].score > 0) {
        var p = scoredCards[i].product;
        // Fallback image if product has no image in Shopify
        var imgUrl = p.image || 'https://cdn.shopify.com/s/files/1/0709/0195/6832/files/1_61136358-8858-46b1-abfb-d48208bff2e6.png';
        var html = `
          <div class="result-card">
            <a href="${p.url}">
              <img src="${imgUrl}" class="result-image" alt="${p.title}">
            </a>
            <div class="result-title">${p.title}</div>
            <div class="result-desc">${p.short_desc}</div>
            <a href="${p.url}" class="result-atc">View Product</a>
          </div>
        `;
        container.innerHTML += html;
        matchCount++;
      }
    }
    
    if (matchCount === 0) {
      document.getElementById('no-results-msg').style.display = 'block';
    }
  }
  
  function resetQuiz() {
    userAnswers = { gender: '', vibe: '', occasion: '' };
    document.getElementById('quiz-results-container').innerHTML = '';
    document.getElementById('no-results-msg').style.display = 'none';
    nextStep(1);
  }
</script>

