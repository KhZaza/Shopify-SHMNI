    </div>
    <div class="about-stat-item scroll-reveal delay-1">
      <h3><span class="counter" data-target="2500">0</span>+</h3>
      <p>Happy Customers</p>
    </div>
    <div class="about-stat-item scroll-reveal delay-2">
      <h3><span class="counter" data-target="50">0</span>+</h3>
