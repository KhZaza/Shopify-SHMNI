<style>
  /* ── Cinematic About Page ── */
  .about-page * { box-sizing: border-box; margin: 0; padding: 0; }

  /* Scroll-reveal animation system */
  .scroll-reveal {
    opacity: 0;
    transform: translateY(60px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .scroll-reveal.revealed {
    opacity: 1;
    transform: translateY(0);
  }
  .scroll-reveal-left {
    opacity: 0;
    transform: translateX(-80px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .scroll-reveal-left.revealed { opacity: 1; transform: translateX(0); }
  .scroll-reveal-right {
    opacity: 0;
    transform: translateX(80px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .scroll-reveal-right.revealed { opacity: 1; transform: translateX(0); }
  .delay-1 { transition-delay: 0.15s; }
  .delay-2 { transition-delay: 0.3s; }
  .delay-3 { transition-delay: 0.45s; }

  /* ── Hero Section ── */
  .about-hero {
    position: relative;
    height: 75vh;
    min-height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: #0a0a0a;
    overflow: hidden;
  }
  .about-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 50%, rgba(212, 175, 55, 0.08) 0%, transparent 70%);
  }
  .about-hero-content { position: relative; z-index: 1; padding: 0 20px; }
  .about-hero-eyebrow {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.35em;
    color: #d4af37;
    margin-bottom: 20px;
    font-weight: 600;
  }
  .about-hero h1 {
    font-size: clamp(36px, 6vw, 72px);
    color: #fff;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1.1;
    margin-bottom: 20px;
  }
  .about-hero-sub {
    font-size: 16px;
    color: rgba(255,255,255,0.5);
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.7;
    letter-spacing: 0.02em;
  }
  .about-hero-scroll-hint {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    color: rgba(255,255,255,0.3);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    animation: about-float 2s ease-in-out infinite;
  }
  .about-hero-scroll-hint svg { width: 20px; height: 20px; }
  @keyframes about-float {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }

  /* ── Stat Counter Section ── */
  .about-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    background: #121212;
    padding: 60px 20px;
    text-align: center;
  }
  @media (max-width: 600px) { .about-stats { grid-template-columns: repeat(2, 1fr); gap: 30px; } }
  .about-stat-item h3 {
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 700;
    color: #d4af37;
    margin-bottom: 6px;
    font-variant-numeric: tabular-nums;
  }
  .about-stat-item p {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255,255,255,0.4);
    font-weight: 600;
  }

  /* ── Story Timeline ── */
  .about-story {
    padding: 100px 20px;
    max-width: 1100px;
    margin: 0 auto;
  }
  .about-story-header {
    text-align: center;
    margin-bottom: 80px;
  }
  .about-story-header h2 {
    font-size: 32px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 700;
    color: #121212;
    margin-bottom: 16px;
  }
  .about-story-header p {
    font-size: 15px;
    color: #888;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
  }
  .about-timeline { position: relative; }
  .about-timeline::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 1px;
    background: linear-gradient(to bottom, transparent, #ddd 10%, #ddd 90%, transparent);
    transform: translateX(-50%);
  }
  @media (max-width: 768px) {
    .about-timeline::before { left: 20px; }
  }
  .about-timeline-item {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    margin-bottom: 80px;
    align-items: center;
    position: relative;
  }
  .about-timeline-item::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 50%;
    width: 12px;
    height: 12px;
    background: #d4af37;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    box-shadow: 0 0 0 4px #fff, 0 0 0 5px #d4af37;
    z-index: 1;
  }
  .about-timeline-item:nth-child(even) .about-timeline-text { order: 2; }
  .about-timeline-item:nth-child(even) .about-timeline-visual { order: 1; }
  @media (max-width: 768px) {
    .about-timeline-item {
      grid-template-columns: 1fr;
      padding-left: 50px;
      gap: 20px;
      margin-bottom: 50px;
    }
    .about-timeline-item::before { left: 20px; }
    .about-timeline-item:nth-child(even) .about-timeline-text { order: 1; }
    .about-timeline-item:nth-child(even) .about-timeline-visual { order: 2; }
  }

  .about-timeline-text h3 {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #d4af37;
    margin-bottom: 10px;
    font-weight: 600;
  }
  .about-timeline-text h4 {
    font-size: 24px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: #121212;
    margin-bottom: 14px;
    text-transform: uppercase;
  }
  .about-timeline-text p {
    font-size: 15px;
    line-height: 1.8;
    color: #666;
  }

  .about-timeline-visual {
    aspect-ratio: 4/3;
    border-radius: 12px;
    overflow: hidden;
    background: #f0f0f0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 48px;
  }

  /* ── Values Section ── */
  .about-values {
    background: #f5f5f0;
    padding: 100px 20px;
  }
  .about-values-inner {
    max-width: 1100px;
    margin: 0 auto;
  }
  .about-values-header {
    text-align: center;
    margin-bottom: 60px;
  }
  .about-values-header h2 {
    font-size: 32px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 700;
    color: #121212;
    margin-bottom: 12px;
  }
  .about-values-header p {
    font-size: 15px;
    color: #888;
  }
  .about-values-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }
  @media (max-width: 768px) { .about-values-grid { grid-template-columns: 1fr; } }
  .about-value-card {
    background: #fff;
    border-radius: 16px;
    padding: 40px 30px;
    text-align: center;
    box-shadow: 0 4px 20px rgba(0,0,0,0.04);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: 1px solid rgba(0,0,0,0.04);
  }
  .about-value-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.08);
  }
  .about-value-icon {
    width: 56px;
    height: 56px;
    margin: 0 auto 20px;
    background: #f5f5f0;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
  }
  .about-value-card h3 {
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 700;
    color: #121212;
    margin-bottom: 12px;
  }
  .about-value-card p {
    font-size: 14px;
    color: #888;
    line-height: 1.7;
  }

  /* ── Full-width Quote ── */
  .about-quote {
    padding: 100px 20px;
    text-align: center;
    background: #121212;
    position: relative;
    overflow: hidden;
  }
  .about-quote::before {
    content: '"';
    position: absolute;
    top: 30px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 200px;
    color: rgba(212, 175, 55, 0.08);
    font-family: Georgia, serif;
    line-height: 1;
  }
  .about-quote blockquote {
    font-size: clamp(20px, 3vw, 30px);
    color: #fff;
    font-style: italic;
    max-width: 800px;
    margin: 0 auto 20px;
    line-height: 1.6;
    letter-spacing: 0.02em;
    position: relative;
    z-index: 1;
  }
  .about-quote cite {
    font-size: 13px;
    color: #d4af37;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-style: normal;
    font-weight: 600;
  }

  /* ── CTA Section ── */
  .about-cta {
    padding: 100px 20px;
    text-align: center;
  }
  .about-cta h2 {
    font-size: 32px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 700;
    color: #121212;
    margin-bottom: 16px;
  }
  .about-cta p {
    font-size: 15px;
    color: #888;
    max-width: 500px;
    margin: 0 auto 32px;
    line-height: 1.7;
  }
  .about-cta-btn {
    display: inline-block;
    padding: 16px 48px;
    background: #121212;
    color: #fff;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 13px;
    font-weight: 600;
    border-radius: 4px;
    transition: all 0.3s ease;
  }
  .about-cta-btn:hover {
    background: #333;
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(0,0,0,0.2);
    color: #fff;
  }

  /* ── Dark Mode ── */
  html.theme-dark .about-story-header h2,
  html.theme-dark .about-timeline-text h4 { color: #fff; }
  html.theme-dark .about-story-header p,
  html.theme-dark .about-timeline-text p { color: #888; }
  html.theme-dark .about-timeline::before { background: linear-gradient(to bottom, transparent, #333 10%, #333 90%, transparent); }
  html.theme-dark .about-timeline-item::before { box-shadow: 0 0 0 4px #0a0a0a, 0 0 0 5px #d4af37; }
  html.theme-dark .about-values { background: #0f0f0f; }
  html.theme-dark .about-value-card { background: #1a1a1a; border-color: rgba(255,255,255,0.06); box-shadow: 0 4px 20px rgba(0,0,0,0.3); }
  html.theme-dark .about-value-card:hover { box-shadow: 0 12px 40px rgba(0,0,0,0.5); }
  html.theme-dark .about-value-icon { background: #222; }
  html.theme-dark .about-value-card h3 { color: #fff; }
  html.theme-dark .about-value-card p { color: #777; }
  html.theme-dark .about-cta h2 { color: #fff; }
  html.theme-dark .about-cta-btn { background: #fff; color: #000; }
  html.theme-dark .about-cta-btn:hover { background: #e0e0e0; color: #000; }
  html.theme-dark .about-story { background: transparent; }

  /* ── Disclaimer ── */
  .about-disclaimer {
    padding: 60px 20px;
    background: #f9f9f9;
    border-top: 1px solid #eee;
  }
  .about-disclaimer-inner {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }
  .about-disclaimer h3 {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #999;
    margin-bottom: 16px;
    font-weight: 600;
  }
  .about-disclaimer p {
    font-size: 12px;
    color: #aaa;
    line-height: 1.8;
    margin-bottom: 12px;
  }
  html.theme-dark .about-disclaimer { background: #0f0f0f; border-color: #222; }
  html.theme-dark .about-disclaimer h3 { color: #555; }
  html.theme-dark .about-disclaimer p { color: #555; }
</style>

